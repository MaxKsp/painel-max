{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Level OS Phase Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "approved",
    "scope",
    "allowedFiles",
    "forbiddenFiles",
    "acceptanceCriteria",
    "risks",
    "requiredTests"
  ],
  "properties": {
    "approved": {
      "type": "boolean"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "allowedFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "forbiddenFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredTests": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
